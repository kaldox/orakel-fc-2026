# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# Langer, zufaelliger Wert. Erzeugen z.B. mit:  openssl rand -hex 32
SECRET_KEY=bitte-hier-einen-langen-zufallswert-eintragen

# Erster Admin-Account (wird beim ersten Start automatisch angelegt).
ADMIN_NAME=admin
ADMIN_PASSWORD=bitte-unbedingt-aendern

# Name der Liga (erscheint im Browser-Tab).
LEAGUE_NAME=ORAKEL FC 2026

# Interner Port im Container (muss zur docker-compose.yml passen).
PORT=8090
